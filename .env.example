# Copy to .env and adjust. All values have working defaults for this repo.

# Where the manuscript lives (chapters/, book-2/chapters/, prequel-novella/chapters/,
# world/). Defaults to this repo — the new book grows here. To browse another
# manuscript checkout instead, set an ABSOLUTE path (~ does not expand here):
# MANUSCRIPT_DIR=/Users/you/RiderProjects/SomeOtherBook
MANUSCRIPT_DIR=.

# Cache-buster for the baked-in UI: recreating containers never de-stales the
# UI — rebuild the image with a fresh value when the UI changed:
#   UI_REBUILD=$(date +%s) docker compose build app && docker compose up -d
UI_REBUILD=0

# Optional shared secret between the app and the host-side claude bridge.
# If set here, start the bridge with the same value:
#   BRIDGE_TOKEN=<value> node bridge/claude-bridge.js
BRIDGE_TOKEN=
